# EditorConfig for XEPMARKET-ALFA Theme
# Enforces UTF-8 without BOM, LF endings, and standard indentation.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.php]
charset = utf-8

[*.js]
indent_size = 2

[*.css]
indent_size = 2

[*.html]
indent_size = 2

[*.json]
indent_size = 2
